[
  {
    "description": "$count of array",
    "expression": "$count([1,2,3])",
    "result": 3
  },
  {
    "description": "$count of empty array",
    "expression": "$count([])",
    "result": 0
  },
  {
    "description": "$count of scalar is 1",
    "expression": "$count(\"hello\")",
    "result": 1
  },
  {
    "description": "$append two arrays",
    "expression": "$append([1,2],[3,4])",
    "result": [1, 2, 3, 4]
  },
  {
    "description": "$append scalar to array",
    "expression": "$append([1,2], 3)",
    "result": [1, 2, 3]
  },
  {
    "description": "$sort ascending",
    "expression": "$sort([3,1,2])",
    "result": [1, 2, 3]
  },
  {
    "description": "$sort strings",
    "expression": "$sort([\"b\",\"a\",\"c\"])",
    "result": ["a", "b", "c"]
  },
  {
    "description": "$reverse",
    "expression": "$reverse([1,2,3])",
    "result": [3, 2, 1]
  },
  {
    "description": "$distinct removes duplicates",
    "expression": "$distinct([1,2,1,3,2])",
    "result": [1, 2, 3]
  },
  {
    "description": "$flatten nested",
    "expression": "$flatten([[1,[2]],3])",
    "result": [1, 2, 3]
  },
  {
    "description": "$zip two arrays",
    "expression": "$zip([1,2,3],[\"a\",\"b\",\"c\"])",
    "result": [[1,"a"],[2,"b"],[3,"c"]]
  }
]
